{
  "$schema": "https://opencode.ai/config.json",
  "lsp": false,
  "skills": {
    "paths": [".claude/skills"]
  },
  "mcp": {
    "duckdb": {
      "command": "uvx",
      "args": [
        "--python",
        "3.11",
        "mcp-server-motherduck",
        "--db-path",
        ":memory:",
        "--read-write"
      ],
      "enabled": true
    }
  }
}
