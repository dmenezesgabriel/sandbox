{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.stryker.config.ts"
  },
  "mutate": ["src/**/*.ts", "!src/**/*.spec.ts"],
  "reporters": ["progress", "html"],
  "concurrency": 4,
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": null
  }
}
