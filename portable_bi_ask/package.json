{
  "name": "portable-bi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src && stylelint 'src/**/*.css'",
    "lint:fix": "eslint src --fix && stylelint 'src/**/*.css' --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview --host 0.0.0.0",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:acceptance": "node --import tsx/esm node_modules/@cucumber/cucumber/bin/cucumber.js 'tests/acceptance/features/**/*.feature' --import 'tests/acceptance/steps/**/*.ts' --format progress --force-exit",
    "test:browser": "node --import tsx/esm node_modules/@cucumber/cucumber/bin/cucumber.js 'tests/browser/features/**/*.feature' --import 'tests/browser/steps/**/*.ts' --format progress --force-exit",
    "test": "vitest run tests/unit && vitest run tests/integration && node --import tsx/esm node_modules/@cucumber/cucumber/bin/cucumber.js 'tests/acceptance/features/**/*.feature' --import 'tests/acceptance/steps/**/*.ts' --format progress --force-exit && node --import tsx/esm node_modules/@cucumber/cucumber/bin/cucumber.js 'tests/browser/features/**/*.feature' --import 'tests/browser/steps/**/*.ts' --format progress --force-exit"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "1.30.0",
    "@huggingface/transformers": "4.0.1",
    "chart.js": "^4.4.9",
    "chrono-node": "2.7.7",
    "fuse.js": "7.0.0",
    "lit": "3.1.0",
    "lucide": "^1.14.0",
    "minisearch": "7.1.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "duckdb": "^1.4.4",
    "eslint": "^10.3.0",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "prettier": "^3.8.3",
    "stylelint": "^17.11.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^5.4.19",
    "vitest": "^4.1.5"
  }
}
