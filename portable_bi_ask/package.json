{
  "name": "portable-bi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "preview": "vite preview --host 0.0.0.0",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:acceptance": "node --import tsx/esm node_modules/@cucumber/cucumber/bin/cucumber.js 'tests/acceptance/features/**/*.feature' --import 'tests/acceptance/steps/**/*.ts' --format progress --force-exit",
    "test": "vitest run tests/unit && vitest run tests/integration && node --import tsx/esm node_modules/@cucumber/cucumber/bin/cucumber.js 'tests/acceptance/features/**/*.feature' --import 'tests/acceptance/steps/**/*.ts' --format progress --force-exit"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "1.30.0",
    "@huggingface/transformers": "4.0.1",
    "chart.js": "^4.4.9",
    "chrono-node": "2.7.7",
    "fuse.js": "7.0.0",
    "lit": "3.1.0",
    "minisearch": "7.1.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.2",
    "duckdb": "^1.4.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.19",
    "vitest": "^4.1.5"
  }
}
